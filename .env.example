HALLU_DEFENSE_ENV=local
HALLU_DEFENSE_POLICY_VERSION=2026-07-07
HALLU_DEFENSE_MAX_REQUEST_BODY_BYTES=1048576
HALLU_DEFENSE_REQUEST_BODY_TIMEOUT_SECONDS=15
HALLU_DEFENSE_POSTGRES_MIGRATION_DSN=
HALLU_DEFENSE_AUTH_REQUIRED=false
HALLU_DEFENSE_AUTH_CLAIMS_MODE=unsigned_headers
HALLU_DEFENSE_AUTH_CLAIMS_SIGNATURE_SECRET_NAME=auth/trusted-header-signing-key
HALLU_DEFENSE_AUTH_CLAIMS_SIGNATURE_TOLERANCE_SECONDS=300
HALLU_DEFENSE_METRICS_BEARER_TOKEN_SECRET_NAME=
HALLU_DEFENSE_CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
HALLU_DEFENSE_OIDC_ISSUER=
HALLU_DEFENSE_OIDC_AUDIENCE=
HALLU_DEFENSE_OIDC_JWKS_PATH=
HALLU_DEFENSE_OIDC_JWKS_URL=
HALLU_DEFENSE_OIDC_DISCOVERY_URL=
HALLU_DEFENSE_OIDC_JWKS_CACHE_TTL_SECONDS=300
HALLU_DEFENSE_OIDC_HTTP_TIMEOUT_SECONDS=3
HALLU_DEFENSE_OIDC_SUBJECT_CLAIM=sub
HALLU_DEFENSE_OIDC_ROLES_CLAIM=roles
HALLU_DEFENSE_OIDC_TENANT_CLAIM=tenant_id
HALLU_DEFENSE_OIDC_CLOCK_SKEW_SECONDS=60
# --- Console runtime auth (read by the running Next server, never baked at build time) ---
# Public demo intake stays disabled until legal approval and all file-backed
# secrets below are provisioned. Never place URLs containing credentials,
# Redis credentials, HMAC keys, or bearer values directly in this file.
HALLU_DEFENSE_DEMO_REQUESTS_ENABLED=false
HALLU_DEFENSE_PRIVACY_CONTACT_EMAIL=
HALLU_DEFENSE_DEMO_WEBHOOK_URL_FILE=
HALLU_DEFENSE_DEMO_WEBHOOK_HMAC_SECRET_FILE=
HALLU_DEFENSE_DEMO_WEBHOOK_ALLOWED_ORIGIN=
HALLU_DEFENSE_DEMO_REDIS_URL_FILE=
HALLU_DEFENSE_DEMO_REDIS_CA_PATH=
HALLU_DEFENSE_CONSOLE_METRICS_BEARER_FILE=
# Compose-only Linux host paths mounted read-only into the Console container.
# When intake is enabled, provision five regular non-symlink files below a
# root-owned directory: owner root, group 10001, mode 0440 (parent mode 0750).
# The production Console receives supplemental group 10001 so its non-root
# `node` user can read only those explicitly mounted files.
HALLU_DEFENSE_DEMO_WEBHOOK_URL_HOST_PATH=
HALLU_DEFENSE_DEMO_WEBHOOK_HMAC_SECRET_HOST_PATH=
HALLU_DEFENSE_DEMO_REDIS_URL_HOST_PATH=
HALLU_DEFENSE_DEMO_REDIS_CA_HOST_PATH=
HALLU_DEFENSE_CONSOLE_METRICS_BEARER_HOST_PATH=
# Production/staging require exact canonical HTTPS origins and OIDC mode.
# HTTP and unsigned identity are accepted only when both explicit local fixture flags are true.
HALLU_DEFENSE_CONSOLE_AUTH_MODE=unsigned-local
HALLU_DEFENSE_CONSOLE_PUBLIC_ORIGIN=http://localhost:3000
HALLU_DEFENSE_CONSOLE_API_ORIGIN=http://localhost:8000
HALLU_DEFENSE_CONSOLE_ALLOW_INSECURE_LOCAL_HTTP=true
HALLU_DEFENSE_CONSOLE_ALLOW_UNSIGNED_LOCAL=true
HALLU_DEFENSE_CONSOLE_DEMO_FIXTURE_ENABLED=false
HALLU_DEFENSE_CONSOLE_LOCAL_TENANT_ID=tenant-a
HALLU_DEFENSE_CONSOLE_LOCAL_SUBJECT_ID=console-reviewer
HALLU_DEFENSE_CONSOLE_LOCAL_ROLES=verifier,approval_reviewer,policy_evaluator,sandbox_runner,tool_operator
# Required instead in OIDC mode:
HALLU_DEFENSE_CONSOLE_OIDC_ISSUER=
HALLU_DEFENSE_CONSOLE_OIDC_CLIENT_ID=hallu-defense-console
HALLU_DEFENSE_CONSOLE_OIDC_API_AUDIENCE=hallu-defense-api
HALLU_DEFENSE_CONSOLE_OIDC_TENANT_CLAIM=tenant_id
HALLU_DEFENSE_CONSOLE_OIDC_ROLES_CLAIM=roles
HALLU_DEFENSE_CONSOLE_OIDC_REQUIRED_ROLES=verifier,approval_reviewer,policy_evaluator,sandbox_runner,tool_operator
HALLU_DEFENSE_CONSOLE_OIDC_CLOCK_SKEW_SECONDS=30
HALLU_DEFENSE_CONSOLE_OIDC_HTTP_TIMEOUT_MS=5000
HALLU_DEFENSE_CONSOLE_OIDC_TRANSACTION_TTL_SECONDS=300
HALLU_DEFENSE_CONSOLE_SESSION_MAX_SECONDS=3600
HALLU_DEFENSE_OIDC_PROVIDER_SMOKE_ENABLED=false
HALLU_DEFENSE_OIDC_PROVIDER_SMOKE_JWT=
HALLU_DEFENSE_OIDC_PROVIDER_SMOKE_EXPECTED_SUBJECT=
HALLU_DEFENSE_OIDC_PROVIDER_SMOKE_EXPECTED_TENANT=
HALLU_DEFENSE_OIDC_PROVIDER_SMOKE_REQUIRED_ROLE=
HALLU_DEFENSE_OPA_ENABLED=false
HALLU_DEFENSE_OPA_PATH=
HALLU_DEFENSE_OPA_POLICY_DIR=infra/opa/policies
HALLU_DEFENSE_OPA_TIMEOUT_SECONDS=3
# Host-side sandbox scope. Relative paths resolve from the process working directory.
HALLU_DEFENSE_ALLOWED_WORKSPACE=.
# Docker is the local/CI isolation boundary; production and staging require
# the tenant-bound Kubernetes backend. Host subprocess execution is forbidden.
HALLU_DEFENSE_SANDBOX_BACKEND=docker
HALLU_DEFENSE_SANDBOX_DOCKER_IMAGE=hallu-defense-sandbox:ci
HALLU_DEFENSE_SANDBOX_DOCKER_PATH=docker
HALLU_DEFENSE_SANDBOX_DOCKER_MEMORY_MB=512
HALLU_DEFENSE_SANDBOX_DOCKER_CPUS=1.0
HALLU_DEFENSE_SANDBOX_DOCKER_PIDS_LIMIT=256
HALLU_DEFENSE_SANDBOX_DOCKER_TIMEOUT_GRACE_SECONDS=2
# Kubernetes backend is fail-closed until every value below is explicit.
# The chart must create a deny-all Egress NetworkPolicy selecting
# hallu-defense.openai.com/network-policy=deny-egress.
HALLU_DEFENSE_SANDBOX_KUBERNETES_IMAGE=
HALLU_DEFENSE_SANDBOX_KUBERNETES_NAMESPACE=
HALLU_DEFENSE_SANDBOX_KUBERNETES_PVC_NAME=
HALLU_DEFENSE_SANDBOX_KUBERNETES_WORKSPACE_MOUNT_PATH=
HALLU_DEFENSE_SANDBOX_KUBERNETES_NETWORK_POLICY_NAME=
HALLU_DEFENSE_SANDBOX_KUBERNETES_TENANT_ID=
HALLU_DEFENSE_SANDBOX_KUBERNETES_POLL_INTERVAL_SECONDS=0.25
HALLU_DEFENSE_SANDBOX_KUBERNETES_JOB_TTL_SECONDS=60
HALLU_DEFENSE_SANDBOX_KUBERNETES_API_REQUEST_TIMEOUT_SECONDS=5
HALLU_DEFENSE_SANDBOX_KUBERNETES_SETUP_GRACE_SECONDS=15
HALLU_DEFENSE_SANDBOX_KUBERNETES_CLEANUP_GRACE_SECONDS=20
# Required by the production Compose overlay; mount a dedicated short-lived
# ServiceAccount token and its CA read-only. Never commit token contents.
KUBERNETES_SERVICE_HOST=
KUBERNETES_SERVICE_PORT_HTTPS=443
HALLU_DEFENSE_SANDBOX_KUBERNETES_TOKEN_HOST_PATH=
HALLU_DEFENSE_SANDBOX_KUBERNETES_CA_HOST_PATH=
HALLU_DEFENSE_OTEL_ENABLED=true
HALLU_DEFENSE_OTEL_SERVICE_NAME=hallu-defense-api
HALLU_DEFENSE_OTEL_EXPORTER=memory
HALLU_DEFENSE_OTEL_ENDPOINT=
# Required and non-empty in production/staging. Comma-separated canonical HTTPS origins only.
HALLU_DEFENSE_OUTBOUND_HTTPS_ALLOWED_ORIGINS=
HALLU_DEFENSE_SECRETS_BACKEND=env
HALLU_DEFENSE_ENV_SECRET_PREFIX=HALLU_DEFENSE_SECRET_
HALLU_DEFENSE_VAULT_ADDR=
HALLU_DEFENSE_VAULT_MOUNT=secret
HALLU_DEFENSE_VAULT_NAMESPACE=
HALLU_DEFENSE_VAULT_TOKEN_ENV=HALLU_DEFENSE_VAULT_TOKEN
# Production one-shot OpenSearch bootstrap uses a separately scoped Vault token.
HALLU_DEFENSE_BOOTSTRAP_VAULT_TOKEN=
HALLU_DEFENSE_VAULT_TIMEOUT_SECONDS=3
HALLU_DEFENSE_VAULT_CA_CERT_PATH=
HALLU_DEFENSE_VAULT_CA_CERT_HOST_PATH=
HALLU_DEFENSE_LOCAL_VAULT_DEV_ROOT_TOKEN=dev-root
HALLU_DEFENSE_LIVE_VAULT_SECRETS_SMOKE_ENABLED=false
HALLU_DEFENSE_LIVE_VAULT_ADDR=http://localhost:8200
HALLU_DEFENSE_LIVE_VAULT_MOUNT=secret
HALLU_DEFENSE_LIVE_VAULT_TOKEN_ENV=HALLU_DEFENSE_LOCAL_VAULT_DEV_ROOT_TOKEN
HALLU_DEFENSE_LIVE_VAULT_TIMEOUT_SECONDS=3
# --- Vault -> OpenAI-compatible -> Ollama live smoke (opt-in; local by default) ---
HALLU_DEFENSE_LIVE_PROVIDER_VAULT_SMOKE_ENABLED=false
HALLU_DEFENSE_LIVE_PROVIDER_VAULT_ADDR=http://127.0.0.1:8200
HALLU_DEFENSE_LIVE_PROVIDER_VAULT_MOUNT=secret
HALLU_DEFENSE_LIVE_PROVIDER_VAULT_TOKEN_ENV=HALLU_DEFENSE_LOCAL_VAULT_DEV_ROOT_TOKEN
HALLU_DEFENSE_LIVE_PROVIDER_VAULT_TIMEOUT_SECONDS=3
HALLU_DEFENSE_LIVE_PROVIDER_OPENAI_BASE_URL=http://127.0.0.1:11434/v1
HALLU_DEFENSE_LIVE_PROVIDER_OLLAMA_BASE_URL=http://127.0.0.1:11434
HALLU_DEFENSE_LIVE_PROVIDER_MODEL=
HALLU_DEFENSE_LIVE_PROVIDER_TIMEOUT_SECONDS=30
HALLU_DEFENSE_LIVE_PROVIDER_SECRET_NAME=providers/openai/api-key
HALLU_DEFENSE_LIVE_PROVIDER_ALLOW_NONLOCAL=false
HALLU_DEFENSE_PROVIDER_BACKEND=mock
HALLU_DEFENSE_PROVIDER_MODEL=mock-verifier
HALLU_DEFENSE_PROVIDER_TIMEOUT_SECONDS=15
HALLU_DEFENSE_PROVIDER_NLI_ENABLED=false
HALLU_DEFENSE_OPENAI_COMPATIBLE_BASE_URL=https://api.openai.com/v1
HALLU_DEFENSE_OPENAI_COMPATIBLE_API_KEY_SECRET_NAME=providers/openai/api-key
HALLU_DEFENSE_OLLAMA_BASE_URL=http://localhost:11434
HALLU_DEFENSE_MOCK_PROVIDER_RESPONSE=mock provider response
HALLU_DEFENSE_RAG_INDEX_BACKEND=local
HALLU_DEFENSE_RAG_INDEX_TIMEOUT_SECONDS=5
HALLU_DEFENSE_OPENSEARCH_ENDPOINT=http://localhost:9200
HALLU_DEFENSE_OPENSEARCH_INDEX_NAME=hallu_evidence
# Production resolves the complete Authorization header (Basic/Bearer/ApiKey)
# from SecretManager/Vault by this name; never put the credential itself here.
# HALLU_DEFENSE_OPENSEARCH_AUTHORIZATION_SECRET_NAME=rag/opensearch/authorization
# Optional private CA for HTTPS OpenSearch endpoints.
# HALLU_DEFENSE_OPENSEARCH_CA_CERT_PATH=/etc/hallu-defense/opensearch/ca.crt
HALLU_DEFENSE_OPENSEARCH_CA_CERT_HOST_PATH=
# Emitted only by the bundled Kind dependency profile for the exact internal service.
HALLU_DEFENSE_OPENSEARCH_KIND_INSECURE_HTTP_ENABLED=false
# Opt-in combined smoke. ADMIN_DSN must target an admin database; the smoke
# creates/drops a random scratch database and never migrates the application DB.
HALLU_DEFENSE_LIVE_HYBRID_RAG_SMOKE_ENABLED=false
HALLU_DEFENSE_LIVE_HYBRID_RAG_ADMIN_DSN=
HALLU_DEFENSE_POSTGRES_DSN=postgresql://hallu:hallu@postgres:5432/hallu_defense
# Production/staging DSNs must set sslmode=verify-full, sslrootcert to this
# absolute in-container path, ssl_min_protocol_version=TLSv1.3, and
# gssencmode=disable so libpq cannot prefer GSS encryption over verified TLS; Compose
# binds the host CA path read-only there.
HALLU_DEFENSE_POSTGRES_CA_CERT_PATH=
HALLU_DEFENSE_POSTGRES_CA_CERT_HOST_PATH=
# Exact disposable Kind pgvector exception only; forbidden for managed/staging DBs.
HALLU_DEFENSE_POSTGRES_KIND_INSECURE_TLS_ENABLED=false
HALLU_DEFENSE_POSTGRES_POOL_MIN_SIZE=1
HALLU_DEFENSE_POSTGRES_POOL_MAX_SIZE=8
HALLU_DEFENSE_POSTGRES_POOL_TIMEOUT_SECONDS=10
HALLU_DEFENSE_PGVECTOR_TABLE_NAME=rag_evidence_chunks
HALLU_DEFENSE_RAG_EMBEDDING_DIMENSION=16
# HALLU_DEFENSE_AUDIT_LEDGER_BACKEND and HALLU_DEFENSE_APPROVAL_QUEUE_BACKEND accept
# `postgres` (requires HALLU_DEFENSE_POSTGRES_DSN). Defaults stay memory/jsonl for local dev.
HALLU_DEFENSE_AUDIT_LEDGER_BACKEND=memory
HALLU_DEFENSE_AUDIT_LEDGER_PATH=var/audit/audit-ledger.jsonl
HALLU_DEFENSE_AUDIT_EXPORT_MAX_RECORDS=1000
# Logical SecretManager/Vault path only; never place commitment key bytes here.
# Production/staging must set this to a Vault secret containing >=32 bytes.
HALLU_DEFENSE_AUDIT_REQUEST_COMMITMENT_SECRET_NAME=
HALLU_DEFENSE_EVAL_REPORTS_BACKEND=memory
HALLU_DEFENSE_EVAL_REPORTS_PATH=var/evals/eval-reports.jsonl
HALLU_DEFENSE_APPROVAL_QUEUE_BACKEND=memory
HALLU_DEFENSE_APPROVAL_QUEUE_PATH=var/approvals/approval-queue.jsonl
# Logical SecretManager/Vault path only; never place commitment key bytes here.
# Production/staging must set this to a Vault secret containing >=32 random bytes
# and provide an opaque, non-secret key ID. During rotation, the previous key
# may overlap for at most seven days; all three previous-key fields are atomic.
HALLU_DEFENSE_APPROVAL_TOOL_CALL_COMMITMENT_SECRET_NAME=
HALLU_DEFENSE_APPROVAL_TOOL_CALL_COMMITMENT_KEY_ID=
HALLU_DEFENSE_APPROVAL_TOOL_CALL_COMMITMENT_PREVIOUS_SECRET_NAME=
HALLU_DEFENSE_APPROVAL_TOOL_CALL_COMMITMENT_PREVIOUS_KEY_ID=
HALLU_DEFENSE_APPROVAL_TOOL_CALL_COMMITMENT_PREVIOUS_VALID_UNTIL=
HALLU_DEFENSE_APPROVAL_EXECUTION_GRANT_TTL_SECONDS=900
HALLU_DEFENSE_TOOL_VALIDATION_RATE_LIMIT_BACKEND=memory
HALLU_DEFENSE_TOOL_VALIDATION_RATE_LIMIT_MAX_REQUESTS=120
HALLU_DEFENSE_TOOL_VALIDATION_RATE_LIMIT_WINDOW_SECONDS=60
HALLU_DEFENSE_TOOL_VALIDATION_RATE_LIMIT_REDIS_URL_SECRET_NAME=quotas/tool-validation/redis-url
HALLU_DEFENSE_TOOL_VALIDATION_RATE_LIMIT_REDIS_TIMEOUT_SECONDS=1
# Direct URL is local/test-only and is useful for the opt-in live Redis smoke.
# HALLU_DEFENSE_TOOL_VALIDATION_RATE_LIMIT_REDIS_URL=redis://localhost:6379/0
# Production/staging require a CA file and a rediss:// URL resolved through Vault.
# HALLU_DEFENSE_TOOL_VALIDATION_RATE_LIMIT_REDIS_CA_PATH=/etc/hallu-defense/redis/ca.crt
HALLU_DEFENSE_TOOL_VALIDATION_RATE_LIMIT_REDIS_CA_HOST_PATH=
HALLU_DEFENSE_CORPUS_GRANTS_BACKEND=memory
HALLU_DEFENSE_CORPUS_GRANTS_PATH=var/rag/corpus-grants.jsonl
HALLU_DEFENSE_CORPUS_GRANTS_TABLE_NAME=rag_corpus_grants
HALLU_DEFENSE_INGESTION_MODE=sync
HALLU_DEFENSE_INGESTION_WORKER_ID=ingestion-worker-local
HALLU_DEFENSE_INGESTION_WORKER_POLL_SECONDS=2
HALLU_DEFENSE_INGESTION_WORKER_BATCH_SIZE=10
HALLU_DEFENSE_INGESTION_WORKER_MAX_ATTEMPTS=5
HALLU_DEFENSE_INGESTION_WORKER_BACKOFF_BASE_SECONDS=30
HALLU_DEFENSE_INGESTION_WORKER_LOCK_TIMEOUT_SECONDS=300
HALLU_DEFENSE_INGESTION_BACKFILL_PAGE_SIZE=100
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me
# --- Keycloak OIDC live smoke (opt-in; does NOT change the app auth defaults above) ---
# Points at the local `keycloak` compose service (realm-hallu-defense) on port 8081.
# These are the namespaced vars the smoke (scripts/dev/live_keycloak_oidc_smoke.py)
# actually reads. They are separate from the base HALLU_DEFENSE_OIDC_* runtime knobs
# above, which stay empty (auth_required=false) so copying this file does not enable
# app-level OIDC verification. Flip SMOKE_ENABLED=true only to run the live smoke.
HALLU_DEFENSE_LIVE_KEYCLOAK_OIDC_SMOKE_ENABLED=false
HALLU_DEFENSE_LIVE_KEYCLOAK_OIDC_ISSUER=http://localhost:8081/realms/hallu-defense
HALLU_DEFENSE_LIVE_KEYCLOAK_OIDC_AUDIENCE=hallu-defense-api
HALLU_DEFENSE_LIVE_KEYCLOAK_OIDC_DISCOVERY_URL=http://localhost:8081/realms/hallu-defense/.well-known/openid-configuration
HALLU_DEFENSE_LIVE_KEYCLOAK_OIDC_SUBJECT_CLAIM=azp
HALLU_DEFENSE_LIVE_KEYCLOAK_OIDC_CLIENT_ID=hallu-defense-api
HALLU_DEFENSE_LIVE_KEYCLOAK_OIDC_CLIENT_SECRET=local-dev-only
HALLU_DEFENSE_LIVE_KEYCLOAK_OIDC_EXPECTED_SUBJECT=hallu-defense-api
HALLU_DEFENSE_LIVE_KEYCLOAK_OIDC_EXPECTED_TENANT=tenant-a
HALLU_DEFENSE_LIVE_KEYCLOAK_OIDC_REQUIRED_ROLE=approval_reviewer
HALLU_DEFENSE_LIVE_KEYCLOAK_OIDC_API_BASE_URL=http://127.0.0.1:18081
HALLU_DEFENSE_LIVE_KEYCLOAK_OIDC_LIMITED_CLIENT_ID=hallu-defense-limited
HALLU_DEFENSE_LIVE_KEYCLOAK_OIDC_LIMITED_CLIENT_SECRET=limited-only
HALLU_DEFENSE_LIVE_KEYCLOAK_OIDC_LIMITED_EXPECTED_SUBJECT=hallu-defense-limited
# --- Browser Console OIDC smoke (opt-in; requires the local Console and Keycloak) ---
HALLU_DEFENSE_LIVE_CONSOLE_OIDC_SMOKE_ENABLED=false
HALLU_DEFENSE_LIVE_CONSOLE_OIDC_CONSOLE_ORIGIN=http://127.0.0.1:3100
HALLU_DEFENSE_LIVE_CONSOLE_OIDC_API_ORIGIN=http://127.0.0.1:18123
HALLU_DEFENSE_LIVE_CONSOLE_OIDC_USERNAME=console-reviewer
HALLU_DEFENSE_LIVE_CONSOLE_OIDC_PASSWORD=console-reviewer-local-only
# --- Docker sandbox live smoke (opt-in; requires local Docker/CI Docker) ---
HALLU_DEFENSE_LIVE_DOCKER_SANDBOX_SMOKE_ENABLED=false
# --- Live observability smokes (opt-in; require local Compose observability services) ---
HALLU_DEFENSE_LIVE_OTEL_EXPORT_CHECK_ENABLED=false
HALLU_DEFENSE_LIVE_OTEL_EXPORT_CHECK_API_BASE_URL=http://localhost:8000
HALLU_DEFENSE_LIVE_OTEL_EXPORT_CHECK_SPANS_PATH=var/otel/spans.jsonl
HALLU_DEFENSE_LIVE_OBSERVABILITY_SMOKE_ENABLED=false
HALLU_DEFENSE_LIVE_OBSERVABILITY_API_URL=http://localhost:8000
HALLU_DEFENSE_LIVE_OBSERVABILITY_PROMETHEUS_URL=http://localhost:9090
HALLU_DEFENSE_LIVE_OBSERVABILITY_GRAFANA_URL=http://localhost:3001
# --- Ingestion worker live smoke (opt-in; requires local Docker/CI Postgres/pgvector) ---
HALLU_DEFENSE_LIVE_INGESTION_WORKER_SMOKE_ENABLED=false
# --- Production profile e2e scaffold (opt-in; requires deployed OIDC token) ---
HALLU_DEFENSE_LIVE_PROD_PROFILE_E2E_ENABLED=false
HALLU_DEFENSE_LIVE_PROD_PROFILE_E2E_API_URL=https://api.example.invalid
HALLU_DEFENSE_LIVE_PROD_PROFILE_E2E_BEARER_TOKEN=
HALLU_DEFENSE_LIVE_PROD_PROFILE_E2E_TENANT=tenant-a
HALLU_DEFENSE_LIVE_PROD_PROFILE_E2E_REPO_REF=.
# --- kind + Helm live smoke scaffold (opt-in; requires kind/kubectl/helm) ---
HALLU_DEFENSE_LIVE_KIND_HELM_SMOKE_ENABLED=false
HALLU_DEFENSE_LIVE_KIND_HELM_CLUSTER=hallu-defense-smoke
HALLU_DEFENSE_LIVE_KIND_HELM_NAMESPACE=hallu-defense
# --- Eval report publish smoke (opt-in; requires a running API) ---
HALLU_DEFENSE_LIVE_EVAL_REPORT_PUBLISH_SMOKE_ENABLED=false
HALLU_DEFENSE_EVAL_REPORT_PUBLISH_API_URL=http://localhost:8000
HALLU_DEFENSE_EVAL_REPORT_PUBLISH_PATH=evals/reports/scenario-metrics.json
HALLU_DEFENSE_EVAL_REPORT_PUBLISH_SUITE=scenarios
HALLU_DEFENSE_EVAL_REPORT_PUBLISH_RUN_ID=local-eval-report

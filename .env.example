HALLU_DEFENSE_EVAL_REPORT_PUBLISH_SUBJECT=eval-publisher
HALLU_DEFENSE_EVAL_REPORT_PUBLISH_ROLES=eval_publisher
HALLU_DEFENSE_EVAL_REPORT_LIST_ROLES=auditor
HALLU_DEFENSE_EVAL_REPORT_PUBLISH_TRACE_ID=tr_eval_publish_smoke
# --- Data lifecycle and backup/restore drills (opt-in; destructive when enabled) ---
HALLU_DEFENSE_RETENTION_EXECUTION_ENABLED=false
HALLU_DEFENSE_RETENTION_EXECUTION_DRY_RUN=true
HALLU_DEFENSE_TENANT_DATA_DELETION_ENABLED=false

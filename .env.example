HALLU_DEFENSE_BACKUP_DRILL_POSTGRES_DB=hallu_defense
HALLU_DEFENSE_BACKUP_DRILL_OUTPUT_DIR=var/backup-drills
# Local SeaweedFS keeps the stable MinIO-named public credential contract.
HALLU_DEFENSE_MINIO_ACCESS_KEY=minioadmin
HALLU_DEFENSE_MINIO_SECRET_KEY=minioadmin
HALLU_DEFENSE_BACKUP_DRILL_MINIO_BUCKET=hallu-backups
HALLU_DEFENSE_BACKUP_DRILL_MINIO_ENDPOINT=http://127.0.0.1:9000
HALLU_DEFENSE_BACKUP_DRILL_MINIO_ACCESS_KEY=minioadmin
HALLU_DEFENSE_BACKUP_DRILL_MINIO_SECRET_KEY=minioadmin
# Production/staging ignore the two plaintext values above and read the
# access_key/secret_key fields from this SecretManager/Vault object.
HALLU_DEFENSE_BACKUP_DRILL_MINIO_CREDENTIALS_SECRET_NAME=backup/minio-credentials
HALLU_DEFENSE_BACKUP_DRILL_MINIO_REGION=us-east-1
HALLU_DEFENSE_BACKUP_DRILL_MAX_BACKUP_BYTES=1073741824
HALLU_DEFENSE_BACKUP_DRILL_TIMEOUT_SECONDS=120

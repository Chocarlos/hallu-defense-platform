{
  "name": "@hallu-defense/console",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build && npm run check:build",
    "check:build": "node ./scripts/check-production-build.mjs",
    "lint": "eslint . --max-warnings=0",
    "start": "next start",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "e2e:web": "next build && next start --port 3100",
    "typecheck": "next typegen && tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@hallu-defense/contracts": "0.1.0",
    "@hallu-defense/sdk": "0.1.0",
    "lucide-react": "^0.468.0",
    "next": "16.2.10",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0"
  }
}

{
  "schema_version": "secrets-policy.v1",
  "production": {
    "backend": "vault",
    "required": true,
    "address_env_var": "HALLU_DEFENSE_VAULT_ADDR",
    "mount_env_var": "HALLU_DEFENSE_VAULT_MOUNT",
    "namespace_env_var": "HALLU_DEFENSE_VAULT_NAMESPACE",
    "token_env_var_reference": "HALLU_DEFENSE_VAULT_TOKEN_ENV",
    "default_token_env_var": "HALLU_DEFENSE_VAULT_TOKEN",
    "log_secret_values": false,
    "audit_secret_values": false
  },
  "local_development": {
    "backend": "env",
    "allowed": true,
    "env_prefix": "HALLU_DEFENSE_SECRET_",
    "forbidden_environments": ["production", "staging"]
  },
  "runtime_controls": {
    "secret_values_are_redacted_by_type": true,
    "secret_names_must_be_relative": true,
    "path_traversal_forbidden": true,
    "startup_requires_vault_token_outside_local": true
  }
}

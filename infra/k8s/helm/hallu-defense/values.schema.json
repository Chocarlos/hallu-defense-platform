{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "hallu-defense Helm values",
  "description": "Closed production and disposable-kind configuration contract.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "global",
    "nameOverride",
    "fullnameOverride",
    "oidc",
    "cors",
    "outboundHttps",
    "ragIndex",
    "opensearch",
    "postgres",
    "vault",
    "provider",
    "otel",
    "rateLimit",
    "networkPolicy",
    "sandbox",
    "api",
    "console",
    "worker",
    "migrations",
    "kindDependencies",
    "secrets"
  ],
  "properties": {
    "global": {
      "type": "object",
      "additionalProperties": false,
      "required": ["imagePullPolicy", "tmpSizeLimit"],
      "properties": {
        "imagePullPolicy": {
          "type": "string",
          "enum": ["Always", "IfNotPresent", "Never"]
        },
        "tmpSizeLimit": { "type": "string", "const": "64Mi" }
      }
    },
    "nameOverride": { "$ref": "#/definitions/dnsLabelOrEmpty" },
    "fullnameOverride": { "$ref": "#/definitions/dnsLabelOrEmpty" },
    "oidc": {
      "type": "object",
      "additionalProperties": false,
      "required": ["issuer", "audience", "jwksPath"],
      "properties": {
        "issuer": { "$ref": "#/definitions/httpsUrlOrEmpty" },
        "audience": { "$ref": "#/definitions/boundedString" },
        "jwksPath": { "type": "string", "const": "/run/hallu-defense/keycloak-jwks.json" }
      }
    },
    "cors": {
      "type": "object",
      "additionalProperties": false,
      "required": ["allowOrigins"],
      "properties": {
        "allowOrigins": { "$ref": "#/definitions/httpsOrigins" }
      }
    },
    "outboundHttps": {
      "type": "object",
      "additionalProperties": false,
      "required": ["allowedOrigins"],
      "properties": {
        "allowedOrigins": { "$ref": "#/definitions/httpsOrigins" }
      }
    },
    "ragIndex": {
      "type": "object",
      "additionalProperties": false,
      "required": ["backend", "timeoutSeconds"],
      "properties": {
        "backend": { "type": "string", "const": "hybrid" },
        "timeoutSeconds": { "type": "integer", "minimum": 1, "maximum": 60 }
      }
    },
    "opensearch": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "endpoint",
        "indexName",
        "authorizationSecretName",
        "caPath",
        "caSecretName",
        "caSecretKey"
      ],
      "properties": {
        "endpoint": {
          "anyOf": [
            { "type": "string", "const": "" },
            { "$ref": "#/definitions/httpsOrigin" },
            { "type": "string", "const": "http://hallu-defense-opensearch:9200" }
          ]
        },
        "indexName": {
          "type": "string",
          "minLength": 1,
          "maxLength": 255,
          "pattern": "^[a-z0-9][a-z0-9_-]*$"
        },
        "authorizationSecretName": { "$ref": "#/definitions/logicalSecretOrEmpty" },
        "caPath": { "type": "string", "const": "/run/hallu-defense/opensearch-ca.pem" },
        "caSecretName": { "$ref": "#/definitions/dnsSubdomainOrEmpty" },
        "caSecretKey": { "$ref": "#/definitions/secretKey" }
      }
    },
    "postgres": {
      "type": "object",
      "additionalProperties": false,
      "required": ["caPath", "caSecretName", "caSecretKey", "kindInsecureTlsEnabled"],
      "properties": {
        "caPath": { "type": "string", "const": "/run/hallu-defense/postgres-ca.pem" },
        "caSecretName": { "$ref": "#/definitions/dnsSubdomainOrEmpty" },
        "caSecretKey": { "$ref": "#/definitions/secretKey" },
        "kindInsecureTlsEnabled": { "type": "boolean" }
      }
    },
    "vault": {
      "type": "object",
      "additionalProperties": false,
      "required": ["address", "mount", "caPath", "caSecretName", "caSecretKey"],
      "properties": {
        "address": { "$ref": "#/definitions/httpsOriginOrEmpty" },
        "mount": { "$ref": "#/definitions/logicalSecret" },
        "caPath": { "type": "string", "const": "/run/hallu-defense/vault-ca.pem" },
        "caSecretName": { "$ref": "#/definitions/dnsSubdomainOrEmpty" },
        "caSecretKey": { "$ref": "#/definitions/secretKey" }
      }
    },
    "provider": {
      "type": "object",
      "additionalProperties": false,
      "required": ["backend", "model", "openaiCompatibleBaseUrl", "apiKeySecretName"],
      "properties": {
        "backend": {
          "type": "string",
          "enum": ["", "openai", "openai-compatible", "ollama"]
        },
        "model": { "$ref": "#/definitions/boundedString" },
        "openaiCompatibleBaseUrl": { "$ref": "#/definitions/httpsUrlOrEmpty" },
        "apiKeySecretName": { "$ref": "#/definitions/logicalSecretOrEmpty" }
      }
    },
    "otel": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "exporter", "endpoint"],
      "properties": {
        "enabled": { "type": "boolean" },
        "exporter": { "type": "string", "const": "otlp" },
        "endpoint": { "$ref": "#/definitions/httpsUrlOrEmpty" }
      }
    },
    "rateLimit": {
      "type": "object",
      "additionalProperties": false,
      "required": ["backend", "redis"],
      "properties": {
        "backend": { "type": "string", "const": "redis" },
        "redis": {
          "type": "object",
          "additionalProperties": false,
          "required": ["urlSecretName", "timeoutSeconds", "caPath", "caSecretName", "caSecretKey"],
          "properties": {
            "urlSecretName": { "$ref": "#/definitions/logicalSecret" },
            "timeoutSeconds": { "type": "integer", "minimum": 1, "maximum": 30 },
            "caPath": { "type": "string", "const": "/run/hallu-defense/redis-ca.pem" },
            "caSecretName": { "$ref": "#/definitions/dnsSubdomainOrEmpty" },
            "caSecretKey": { "$ref": "#/definitions/secretKey" }
          }
        }
      }
    },
    "networkPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kubernetesApi", "ingress", "api", "console", "worker", "migrations"],
      "properties": {
        "kubernetesApi": {
          "type": "array",
          "maxItems": 16,
          "uniqueItems": true,
          "items": { "$ref": "#/definitions/cidrPortPeer" }
        },
        "ingress": {
          "type": "object",
          "additionalProperties": false,
          "required": ["api", "worker", "console"],
          "properties": {
            "api": {
              "type": "object",
              "additionalProperties": false,
              "required": ["callers", "metricsScrapers"],
              "properties": {
                "callers": { "$ref": "#/definitions/ingressPeers" },
                "metricsScrapers": { "$ref": "#/definitions/ingressPeers" }
              }
            },
            "worker": {
              "type": "object",
              "additionalProperties": false,
              "required": ["metricsScrapers"],
              "properties": {
                "metricsScrapers": { "$ref": "#/definitions/ingressPeers" }
              }
            },
            "console": {
              "type": "object",
              "additionalProperties": false,
              "required": ["callers"],
              "properties": {
                "callers": { "$ref": "#/definitions/ingressPeers" }
              }
            }
          }
        },
        "api": { "$ref": "#/definitions/externalPolicy" },
        "console": { "$ref": "#/definitions/externalPolicy" },
        "worker": { "$ref": "#/definitions/externalPolicy" },
        "migrations": { "$ref": "#/definitions/externalPolicy" }
      }
    },
    "sandbox": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "backend",
        "namespace",
        "tenantId",
        "image",
        "commandTimeoutSeconds",
        "pollIntervalSeconds",
        "jobTtlSeconds",
        "apiRequestTimeoutSeconds",
        "cleanupGraceSeconds",
        "setupGraceSeconds",
        "resources",
        "workspace",
        "fixture"
      ],
      "properties": {
        "backend": { "type": "string", "const": "kubernetes" },
        "namespace": { "$ref": "#/definitions/dnsLabelOrEmpty" },
        "tenantId": {
          "type": "string",
          "maxLength": 128,
          "pattern": "^(?:|[A-Za-z0-9](?:[-A-Za-z0-9_.]*[A-Za-z0-9])?)$"
        },
        "image": {
          "type": "object",
          "additionalProperties": false,
          "required": ["reference", "pullPolicy"],
          "properties": {
            "reference": { "$ref": "#/definitions/imageReferenceOrEmpty" },
            "pullPolicy": {
              "type": "string",
              "enum": ["Always", "IfNotPresent", "Never"]
            }
          }
        },
        "commandTimeoutSeconds": { "type": "integer", "minimum": 1, "maximum": 900 },
        "pollIntervalSeconds": { "type": "number", "exclusiveMinimum": 0, "maximum": 10 },
        "jobTtlSeconds": { "type": "integer", "minimum": 1, "maximum": 86400 },
        "apiRequestTimeoutSeconds": { "type": "integer", "minimum": 1, "maximum": 60 },
        "cleanupGraceSeconds": { "type": "integer", "minimum": 15, "maximum": 30 },
        "setupGraceSeconds": { "type": "integer", "minimum": 5, "maximum": 60 },
        "resources": {
          "type": "object",
          "additionalProperties": false,
          "required": ["cpu", "memoryMb", "pidsLimit"],
          "properties": {
            "cpu": { "$ref": "#/definitions/cpuQuantity" },
            "memoryMb": { "type": "integer", "minimum": 64, "maximum": 32768 },
            "pidsLimit": { "type": "integer", "minimum": 16, "maximum": 4096 }
          }
        },
        "workspace": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "mountPath",
            "apiExistingClaim",
            "existingClaim",
            "createClaim",
            "storage",
            "accessModes"
          ],
          "properties": {
            "mountPath": { "type": "string", "const": "/workspace" },
            "apiExistingClaim": { "$ref": "#/definitions/dnsSubdomainOrEmpty" },
            "existingClaim": { "$ref": "#/definitions/dnsSubdomainOrEmpty" },
            "createClaim": { "type": "boolean" },
            "storage": { "$ref": "#/definitions/storageQuantity" },
            "accessModes": {
              "type": "array",
              "minItems": 1,
              "maxItems": 2,
              "uniqueItems": true,
              "items": {
                "type": "string",
                "enum": ["ReadWriteOnce", "ReadWriteMany"]
              }
            }
          }
        },
        "fixture": {
          "type": "object",
          "additionalProperties": false,
          "required": ["enabled", "repositoryName"],
          "properties": {
            "enabled": { "type": "boolean" },
            "repositoryName": { "$ref": "#/definitions/dnsLabel" }
          }
        }
      }
    },
    "api": {
      "type": "object",
      "additionalProperties": false,
      "required": ["replicas", "image", "service", "podAnnotations", "resources"],
      "properties": {
        "replicas": { "type": "integer", "minimum": 1, "maximum": 64 },
        "image": { "$ref": "#/definitions/workloadImage" },
        "service": {
          "type": "object",
          "additionalProperties": false,
          "required": ["port"],
          "properties": {
            "port": { "type": "integer", "const": 8000 }
          }
        },
        "podAnnotations": { "$ref": "#/definitions/apiPrometheusAnnotations" },
        "resources": { "$ref": "#/definitions/resources" }
      }
    },
    "console": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "replicas",
        "image",
        "publicOrigin",
        "apiOrigin",
        "oidc",
        "service",
        "resources"
      ],
      "properties": {
        "replicas": { "type": "integer", "const": 1 },
        "image": { "$ref": "#/definitions/workloadImage" },
        "publicOrigin": { "$ref": "#/definitions/httpsOriginOrEmpty" },
        "apiOrigin": { "$ref": "#/definitions/httpsOriginOrEmpty" },
        "oidc": {
          "type": "object",
          "additionalProperties": false,
          "required": ["issuer", "clientId", "apiAudience"],
          "properties": {
            "issuer": { "$ref": "#/definitions/httpsUrlOrEmpty" },
            "clientId": { "$ref": "#/definitions/boundedString" },
            "apiAudience": { "$ref": "#/definitions/boundedString" }
          }
        },
        "service": {
          "type": "object",
          "additionalProperties": false,
          "required": ["port"],
          "properties": {
            "port": { "type": "integer", "const": 3000 }
          }
        },
        "resources": { "$ref": "#/definitions/resources" }
      }
    },
    "worker": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabled",
        "replicas",
        "image",
        "command",
        "metricsPort",
        "setupGraceSeconds",
        "podAnnotations",
        "resources"
      ],
      "properties": {
        "enabled": { "type": "boolean", "const": true },
        "replicas": { "type": "integer", "minimum": 1, "maximum": 64 },
        "image": { "$ref": "#/definitions/workloadImage" },
        "command": {
          "type": "array",
          "const": [
            "python",
            "-m",
            "hallu_defense.worker",
            "--metrics-host",
            "0.0.0.0",
            "--metrics-port",
            "9090"
          ]
        },
        "metricsPort": { "type": "integer", "const": 9090 },
        "setupGraceSeconds": { "type": "integer", "minimum": 1, "maximum": 300 },
        "podAnnotations": { "$ref": "#/definitions/workerPrometheusAnnotations" },
        "resources": { "$ref": "#/definitions/resources" }
      }
    },
    "migrations": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabled",
        "expectedCount",
        "expectedChecksums",
        "waitTimeoutSeconds",
        "image",
        "command"
      ],
      "properties": {
        "enabled": { "type": "boolean", "const": true },

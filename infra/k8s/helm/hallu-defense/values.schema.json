          }
        },
        "waitTimeoutSeconds": { "type": "integer", "minimum": 30, "maximum": 600 },
        "image": { "$ref": "#/definitions/workloadImage" },
        "command": {
          "type": "array",
          "const": ["python", "scripts/dev/apply_postgres_migrations.py"]
        }
      }
    },
    "kindDependencies": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "vault", "pgvector", "opensearch", "redis"],
      "properties": {
        "enabled": { "type": "boolean" },
        "vault": {
          "type": "object",
          "additionalProperties": false,
          "required": ["enabled", "image", "resources"],
          "properties": {
            "enabled": { "type": "boolean" },
            "image": {
              "type": "string",
              "const": "hashicorp/vault:2.0.3@sha256:a296a888b118615dc01d5f1a6846e6d4a7277946caaed5b447008fff5fe06b54"
            },
            "resources": { "$ref": "#/definitions/resources" }
          }
        },
        "pgvector": {
          "type": "object",
          "additionalProperties": false,
          "required": ["enabled", "image", "storage", "resources"],
          "properties": {
            "enabled": { "type": "boolean" },
            "image": { "$ref": "#/definitions/imageReference" },
            "storage": { "$ref": "#/definitions/storageQuantity" },
            "resources": { "$ref": "#/definitions/resources" }
          }
        },
        "opensearch": {
          "type": "object",
          "additionalProperties": false,
          "required": ["enabled", "image", "storage", "resources"],
          "properties": {
            "enabled": { "type": "boolean" },
            "image": { "$ref": "#/definitions/imageReference" },
            "storage": { "$ref": "#/definitions/storageQuantity" },
            "resources": { "$ref": "#/definitions/resources" }
          }
        },
        "redis": {
          "type": "object",
          "additionalProperties": false,
          "required": ["enabled", "image", "resources"],
          "properties": {
            "enabled": { "type": "boolean" },
            "image": {
              "type": "string",
              "const": "redis:7-alpine@sha256:6ab0b6e7381779332f97b8ca76193e45b0756f38d4c0dcda72dbb3c32061ab99"
            },
            "resources": {
              "type": "object",
              "additionalProperties": false,
              "required": ["server", "guard"],
              "properties": {
                "server": { "$ref": "#/definitions/resources" },
                "guard": { "$ref": "#/definitions/resources" }
              }
            }
          }
        }
      }

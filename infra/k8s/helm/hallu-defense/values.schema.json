            "001_rag_evidence_chunks.sql": { "type": "string", "const": "d83ab44c8292b637aeb50bddda4852734e661fd622c97cf280ef1910fdcd9665" },
            "002_rag_corpus_grants.sql": { "type": "string", "const": "1f71be2ff06b0099bac08338b66ed727b2e2c76d61975e9ba37b3bcd95eaf957" },
            "003_audit_ledger.sql": { "type": "string", "const": "622afd56f9005bbe6617dd70a773aaeaf274ba981dcac08b3386db24144c8a38" },
            "004_approval_queue.sql": { "type": "string", "const": "5b9de7132204a849f84448407f1c34ec5b65dd3f4e2064a6e03d8dfeb234b2fc" },
            "005_eval_reports.sql": { "type": "string", "const": "1174b785a36ec7ab20c3d7ea4a44b5ecbf8c72aa5eb26aeeebffedfe86c7008a" },
            "006_ingestion_outbox.sql": { "type": "string", "const": "65c5261eef78ef85d87d3d4c0a0a53801215908bd6976d4d1b2315adffad3d22" },
            "007_ingestion_lease_fencing.sql": { "type": "string", "const": "5444d0b3bacbc10aaa25f58af903a732545caccbe0f534bf1d4aed7e412e406f" },
            "008_schema_migration_checksums.sql": { "type": "string", "const": "bf79b45a1015f553f6f4516761d541bc1f4106c2f40bf52969e6c18fd951651f" },
            "009_drop_unsafe_ivfflat.sql": { "type": "string", "const": "aec207e341e290b9ce881d0cb29efc8c5ff87d62760e08f949b8afb6e1fa2ab7" },

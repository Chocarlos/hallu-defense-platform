    "secrets": {
      "type": "object",
      "additionalProperties": false,
      "required": ["runtime", "bootstrap", "migrations", "kindPostgres", "kindVault", "kindRedisTls"],
      "properties": {
        "runtime": {
          "type": "object",
          "additionalProperties": false,
          "required": ["name", "keycloakJwksKey", "vaultTokenKey", "postgresDsnKey"],
          "properties": {
            "name": { "$ref": "#/definitions/dnsSubdomainOrEmpty" },
            "keycloakJwksKey": { "$ref": "#/definitions/secretKey" },
            "vaultTokenKey": { "$ref": "#/definitions/secretKey" },
            "postgresDsnKey": { "$ref": "#/definitions/secretKey" }
          }
        },
        "bootstrap": {
          "type": "object",
          "additionalProperties": false,
          "required": ["name", "vaultTokenKey"],
          "properties": {
            "name": { "$ref": "#/definitions/dnsSubdomainOrEmpty" },
            "vaultTokenKey": { "$ref": "#/definitions/secretKey" }
          }
        },
        "migrations": {
          "type": "object",
          "additionalProperties": false,
          "required": ["name", "postgresDsnKey"],
          "properties": {
            "name": { "$ref": "#/definitions/dnsSubdomainOrEmpty" },
            "postgresDsnKey": { "$ref": "#/definitions/secretKey" }
          }
        },
        "kindPostgres": { "$ref": "#/definitions/secretNameReference" },
        "kindVault": { "$ref": "#/definitions/secretNameReference" },
        "kindRedisTls": { "$ref": "#/definitions/secretNameReference" }
      }
    }
  },
  "definitions": {
    "boundedString": {
      "type": "string",
      "maxLength": 512
    },
    "dnsLabel": {
      "type": "string",
      "minLength": 1,
      "maxLength": 63,
      "pattern": "^[a-z0-9](?:[-a-z0-9]*[a-z0-9])?$"
    },
    "dnsLabelOrEmpty": {
      "type": "string",
      "maxLength": 63,
      "pattern": "^(?:|[a-z0-9](?:[-a-z0-9]*[a-z0-9])?)$"
    },
    "dnsSubdomainOrEmpty": {
      "type": "string",
      "maxLength": 253,
      "pattern": "^(?:|[a-z0-9](?:[-a-z0-9]*[a-z0-9])?(?:\\.[a-z0-9](?:[-a-z0-9]*[a-z0-9])?)*)$"
    },
    "secretKey": {
      "type": "string",
      "minLength": 1,
      "maxLength": 253,
      "pattern": "^[A-Za-z0-9._-]+$"
    },
    "logicalSecret": {
      "type": "string",
      "minLength": 1,
      "maxLength": 253,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*(?:/[A-Za-z0-9][A-Za-z0-9._-]*)*$"
    },
    "logicalSecretOrEmpty": {
      "type": "string",
      "maxLength": 253,
      "pattern": "^(?:|[A-Za-z0-9][A-Za-z0-9._-]*(?:/[A-Za-z0-9][A-Za-z0-9._-]*)*)$"
    },
    "absolutePath": {
      "type": "string",
      "minLength": 2,
      "maxLength": 512,
      "pattern": "^/[A-Za-z0-9][A-Za-z0-9._-]*(?:/[A-Za-z0-9][A-Za-z0-9._-]*)*$"
    },
    "httpsUrl": {
      "type": "string",
      "minLength": 9,
      "maxLength": 2048,
      "pattern": "^https://[A-Za-z0-9](?:[-A-Za-z0-9]{0,61}[A-Za-z0-9])?(?:\\.[A-Za-z0-9](?:[-A-Za-z0-9]{0,61}[A-Za-z0-9])?)*(?::(?:[1-9][0-9]{0,3}|[1-5][0-9]{4}|6[0-4][0-9]{3}|65[0-4][0-9]{2}|655[0-2][0-9]|6553[0-5]))?(?:/[A-Za-z0-9._~!$&'()*+,;=:%/-]*)?$"
    },
    "httpsUrlOrEmpty": {
      "type": "string",
      "maxLength": 2048,
      "pattern": "^(?:|https://[A-Za-z0-9](?:[-A-Za-z0-9]{0,61}[A-Za-z0-9])?(?:\\.[A-Za-z0-9](?:[-A-Za-z0-9]{0,61}[A-Za-z0-9])?)*(?::(?:[1-9][0-9]{0,3}|[1-5][0-9]{4}|6[0-4][0-9]{3}|65[0-4][0-9]{2}|655[0-2][0-9]|6553[0-5]))?(?:/[A-Za-z0-9._~!$&'()*+,;=:%/-]*)?)$"
    },
    "httpsOrigin": {
      "type": "string",
      "minLength": 9,
      "maxLength": 2048,
      "pattern": "^https://[A-Za-z0-9](?:[-A-Za-z0-9]{0,61}[A-Za-z0-9])?(?:\\.[A-Za-z0-9](?:[-A-Za-z0-9]{0,61}[A-Za-z0-9])?)*(?::(?:[1-9][0-9]{0,3}|[1-5][0-9]{4}|6[0-4][0-9]{3}|65[0-4][0-9]{2}|655[0-2][0-9]|6553[0-5]))?$"
    },
    "httpsOriginOrEmpty": {
      "type": "string",
      "maxLength": 2048,
      "pattern": "^(?:|https://[A-Za-z0-9](?:[-A-Za-z0-9]{0,61}[A-Za-z0-9])?(?:\\.[A-Za-z0-9](?:[-A-Za-z0-9]{0,61}[A-Za-z0-9])?)*(?::(?:[1-9][0-9]{0,3}|[1-5][0-9]{4}|6[0-4][0-9]{3}|65[0-4][0-9]{2}|655[0-2][0-9]|6553[0-5]))?)$"
    },
    "httpsOrigins": {
      "type": "array",
      "maxItems": 32,
      "uniqueItems": true,
      "items": { "$ref": "#/definitions/httpsOrigin" }
    },
    "imageReference": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512,
      "pattern": "^[A-Za-z0-9._/@:+-]+$"
    },
    "imageReferenceOrEmpty": {
      "type": "string",
      "maxLength": 512,
      "pattern": "^(?:|[A-Za-z0-9._/@:+-]+)$"
    },
    "workloadImage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reference"],
      "properties": {
        "reference": { "$ref": "#/definitions/imageReferenceOrEmpty" }
      }
    },
    "cpuQuantity": {
      "type": "string",
      "maxLength": 32,
      "pattern": "^(?:[1-9][0-9]*m|0\\.[0-9]*[1-9][0-9]*|[1-9][0-9]*(?:\\.[0-9]+)?)$"
    },
    "memoryQuantity": {
      "type": "string",
      "maxLength": 32,
      "pattern": "^[1-9][0-9]*(?:Ki|Mi|Gi)$"
    },
    "storageQuantity": {
      "type": "string",
      "maxLength": 32,
      "pattern": "^[1-9][0-9]*(?:Ki|Mi|Gi|Ti)$"
    },
    "resourcePair": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cpu", "memory"],
      "properties": {
        "cpu": { "$ref": "#/definitions/cpuQuantity" },
        "memory": { "$ref": "#/definitions/memoryQuantity" }
      }
    },
    "resources": {
      "type": "object",
      "additionalProperties": false,
      "required": ["requests", "limits"],
      "properties": {
        "requests": { "$ref": "#/definitions/resourcePair" },
        "limits": { "$ref": "#/definitions/resourcePair" }
      }
    },
    "cidr": {
      "oneOf": [
        {
          "type": "string",
          "pattern": "^(?:(?:0|[1-9][0-9]?|1[0-9]{2}|2[0-4][0-9]|25[0-5])\\.){3}(?:0|[1-9][0-9]?|1[0-9]{2}|2[0-4][0-9]|25[0-5])/32$"
        },
        {
          "type": "string",
          "minLength": 5,
          "maxLength": 47,
          "pattern": "^(?:(?:[0-9a-f]{1,4}:){7}[0-9a-f]{1,4}|(?:[0-9a-f]{1,4}:){1,7}:|(?:[0-9a-f]{1,4}:){1,6}:[0-9a-f]{1,4}|(?:[0-9a-f]{1,4}:){1,5}(?::[0-9a-f]{1,4}){1,2}|(?:[0-9a-f]{1,4}:){1,4}(?::[0-9a-f]{1,4}){1,3}|(?:[0-9a-f]{1,4}:){1,3}(?::[0-9a-f]{1,4}){1,4}|(?:[0-9a-f]{1,4}:){1,2}(?::[0-9a-f]{1,4}){1,5}|[0-9a-f]{1,4}:(?:(?::[0-9a-f]{1,4}){1,6})|:(?:(?::[0-9a-f]{1,4}){1,7}|:))/128$"
        }
      ]
    },
    "port": {
      "type": "integer",
      "minimum": 1,
      "maximum": 65535
    },
    "cidrPortPeer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cidr", "port"],
      "properties": {
        "cidr": { "$ref": "#/definitions/cidr" },
        "port": { "$ref": "#/definitions/port" }
      }
    },
    "namedCidrPortPeer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "cidr", "port"],
      "properties": {
        "name": { "$ref": "#/definitions/dnsLabel" },
        "cidr": { "$ref": "#/definitions/cidr" },
        "port": { "$ref": "#/definitions/port" }
      }
    },
    "externalPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["external"],
      "properties": {
        "external": {
          "type": "array",
          "maxItems": 64,
          "items": { "$ref": "#/definitions/namedCidrPortPeer" }
        }
      }
    },
    "ingressPeer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "namespace", "podLabelKey", "podLabelValue"],
      "properties": {
        "name": { "$ref": "#/definitions/dnsLabel" },
        "namespace": {
          "type": "string",
          "minLength": 1,
          "maxLength": 63,
          "pattern": "^(?:\\$release|[a-z0-9](?:[-a-z0-9]*[a-z0-9])?)$"
        },
        "podLabelKey": {
          "type": "string",
          "minLength": 1,
          "maxLength": 253,
          "pattern": "^(?:[a-z0-9](?:[-a-z0-9]{0,61}[a-z0-9])?(?:\\.[a-z0-9](?:[-a-z0-9]{0,61}[a-z0-9])?)*/)?[A-Za-z0-9](?:[-A-Za-z0-9_.]{0,61}[A-Za-z0-9])?$"
        },
        "podLabelValue": {
          "type": "string",
          "minLength": 1,
          "maxLength": 63,
          "pattern": "^[A-Za-z0-9](?:[-A-Za-z0-9_.]*[A-Za-z0-9])?$"
        }
      }
    },
    "ingressPeers": {
      "type": "array",
      "maxItems": 64,
      "items": { "$ref": "#/definitions/ingressPeer" }
    },
    "apiPrometheusAnnotations": {
      "type": "object",
      "additionalProperties": false,
      "required": ["prometheus.io/scrape", "prometheus.io/path", "prometheus.io/port"],
      "properties": {
        "prometheus.io/scrape": { "type": "string", "const": "true" },
        "prometheus.io/path": { "type": "string", "const": "/metrics" },
        "prometheus.io/port": { "type": "string", "const": "8000" }
      }
    },
    "workerPrometheusAnnotations": {
      "type": "object",
      "additionalProperties": false,
      "required": ["prometheus.io/scrape", "prometheus.io/path", "prometheus.io/port"],
      "properties": {
        "prometheus.io/scrape": { "type": "string", "const": "true" },
        "prometheus.io/path": { "type": "string", "const": "/metrics" },
        "prometheus.io/port": { "type": "string", "const": "9090" }
      }
    },
    "secretNameReference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": { "$ref": "#/definitions/dnsSubdomainOrEmpty" }
      }
    }
  }
}

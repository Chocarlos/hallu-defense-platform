{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hallu-defense.local/schemas/document-ingestion-request.schema.json",
  "title": "DocumentIngestionRequest",
  "type": "object",
  "required": ["documents"],
  "properties": {
    "documents": {
      "type": "array",
      "minItems": 1,
      "maxItems": 100,
      "items": { "$ref": "https://hallu-defense.local/schemas/document-input.schema.json" }
    },
    "corpus_id": { "type": "string", "minLength": 1 }
  },
  "additionalProperties": false
}

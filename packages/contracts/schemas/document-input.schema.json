{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hallu-defense.local/schemas/document-input.schema.json",
  "title": "DocumentInput",
  "type": "object",
  "required": ["source_ref", "content", "authority"],
  "properties": {
    "source_ref": { "type": "string", "minLength": 1 },
    "content": { "type": "string", "minLength": 1 },
    "authority": {
      "type": "string",
      "enum": ["official", "internal", "trusted_third_party", "unknown"]
    },
    "metadata": { "type": "object", "additionalProperties": true }
  },
  "additionalProperties": false
}

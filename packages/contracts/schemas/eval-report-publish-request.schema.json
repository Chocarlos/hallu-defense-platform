{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hallu-defense.local/schemas/eval-report-publish-request.schema.json",
  "title": "EvalReportPublishRequest",
  "type": "object",
  "required": ["suite", "run_id", "metrics"],
  "properties": {
    "suite": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80,
      "pattern": "^[A-Za-z0-9_.-]+$"
    },
    "run_id": { "type": "string", "minLength": 1, "maxLength": 120 },
    "source": { "type": "string", "minLength": 1, "maxLength": 120 },
    "metrics": { "$ref": "eval-report-metrics.schema.json" },
    "payload": { "type": "object", "additionalProperties": true }
  },
  "additionalProperties": false
}

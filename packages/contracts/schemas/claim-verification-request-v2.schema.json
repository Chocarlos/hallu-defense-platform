{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hallu-defense.local/schemas/claim-verification-request-v2.schema.json",
  "title": "ClaimVerificationRequestV2",
  "x-contract-version": "2.0",
  "type": "object",
  "required": ["schema_version", "claims"],
  "properties": {
    "schema_version": { "const": "2.0", "type": "string" },
    "claims": {
      "type": "array",
      "items": { "$ref": "claim.schema.json" }
    },
    "evidence": {
      "type": "array",
      "items": { "$ref": "evidence.schema.json" }
    }
  },
  "additionalProperties": false
}

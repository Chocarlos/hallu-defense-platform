{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hallu-defense.local/schemas/release-encryption-evidence.schema.json",
  "title": "ReleaseEncryptionEvidence",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "bundle_id",
    "sequence",
    "nonce",
    "issued_at",
    "expires_at",
    "subject",
    "provenance",
    "attestations",
    "rotation",
    "commitments",
    "authenticators"
  ],
  "properties": {
    "schema_version": {
      "const": "release-encryption-evidence.v1"
    },
    "bundle_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{7,127}$"
    },
    "sequence": {
      "type": "integer",
      "minimum": 1
    },
    "nonce": {
      "type": "string",
      "pattern": "^[0-9a-f]{32,64}$"
    },
    "issued_at": {
      "type": "string",
      "format": "date-time"
    },
    "expires_at": {
      "type": "string",
      "format": "date-time"
    },
    "subject": {
      "$ref": "#/$defs/subject"
    },
    "provenance": {
      "$ref": "#/$defs/provenance"
    },
    "attestations": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "items": {
        "oneOf": [
          {"$ref": "#/$defs/at_rest_attestation"},
          {"$ref": "#/$defs/in_transit_attestation"}
        ]
      }
    },
    "rotation": {
      "$ref": "#/$defs/rotation"
    },
    "commitments": {
      "type": "array",
      "minItems": 1,
      "maxItems": 2,
      "items": {
        "$ref": "#/$defs/auth_tag"
      }
    },
    "authenticators": {
      "type": "array",
      "minItems": 1,
      "maxItems": 2,
      "items": {
        "$ref": "#/$defs/authenticator"
      }
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "identifier": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{2,127}$"
    },
    "subject": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tenant_id",
        "environment",
        "release_id",
        "deployment_revision",
        "deployment_sha256",
        "encryption_policy_sha256",
        "evidence_schema_sha256",
        "trust_store_sha256"
      ],
      "properties": {
        "tenant_id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9_-]{2,63}$"
        },
        "environment": {
          "enum": ["staging", "production"]
        },
        "release_id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{2,127}$"
        },
        "deployment_revision": {
          "type": "integer",
          "minimum": 1
        },
        "deployment_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "encryption_policy_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "evidence_schema_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "trust_store_sha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "material": {
      "type": "object",
      "additionalProperties": false,
      "required": ["uri", "sha256"],
      "properties": {
        "uri": {
          "type": "string",
          "pattern": "^(deployment-subject|workflow-definition|artifact:[a-z0-9][a-z0-9._-]{1,63}|attestation:encryption\\.(at-rest|in-transit)|postgres-ca-rollout)$"
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "issuer",
        "builder_id",
        "workflow_ref",
        "source_repository",
        "source_commit",
        "invocation_id",
        "started_at",
        "finished_at",
        "materials"
      ],
      "properties": {
        "issuer": {
          "type": "string",
          "minLength": 3,
          "maxLength": 256
        },
        "builder_id": {
          "type": "string",
          "minLength": 3,
          "maxLength": 512
        },
        "workflow_ref": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._/@-]{3,512}$"
        },
        "source_repository": {
          "type": "string",
          "pattern": "^https://[A-Za-z0-9._/-]+$",
          "maxLength": 512
        },
        "source_commit": {
          "type": "string",
          "pattern": "^[0-9a-f]{40}([0-9a-f]{24})?$"
        },
        "invocation_id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{7,255}$"
        },
        "started_at": {
          "type": "string",
          "format": "date-time"
        },
        "finished_at": {
          "type": "string",
          "format": "date-time"
        },
        "materials": {
          "type": "array",
          "minItems": 5,
          "maxItems": 68,
          "items": {
            "$ref": "#/$defs/material"
          }
        }
      }
    },
    "at_rest_claims": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "persistent_resources_verified",
        "resource_ids",
        "unencrypted_persistent_resources",
        "algorithms",
        "kms_authority_ids",
        "deployment_hash_observed",
        "evidence_sha256"
      ],
      "properties": {
        "persistent_resources_verified": {
          "type": "integer",
          "minimum": 1
        },
        "resource_ids": {
          "type": "array",
          "minItems": 1,
          "maxItems": 64,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9._-]{1,63}$"
          }
        },
        "unencrypted_persistent_resources": {
          "const": 0
        },
        "algorithms": {
          "type": "array",
          "minItems": 1,
          "maxItems": 16,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[A-Z0-9][A-Z0-9._-]{2,63}$"
          }
        },
        "kms_authority_ids": {
          "type": "array",
          "minItems": 1,
          "maxItems": 16,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 3,
            "maxLength": 256
          }
        },
        "deployment_hash_observed": {
          "const": true
        },
        "evidence_sha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "in_transit_claims": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "external_endpoints_verified",
        "endpoint_ids",
        "plaintext_external_endpoints",
        "minimum_tls_version",
        "trust_chain_validated",
        "peer_ca_sha256",
        "deployment_hash_observed",
        "evidence_sha256"
      ],
      "properties": {
        "external_endpoints_verified": {
          "type": "integer",
          "minimum": 1
        },
        "endpoint_ids": {
          "type": "array",
          "minItems": 1,
          "maxItems": 64,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9._-]{1,63}$"
          }
        },
        "plaintext_external_endpoints": {
          "const": 0
        },
        "minimum_tls_version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+$"
        },
        "trust_chain_validated": {
          "const": true
        },
        "peer_ca_sha256": {
          "type": "array",
          "minItems": 1,
          "maxItems": 32,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/sha256"
          }
        },
        "deployment_hash_observed": {
          "const": true
        },
        "evidence_sha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "at_rest_attestation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["control", "result", "subject_sha256", "observed_at", "claims"],
      "properties": {
        "control": {
          "const": "encryption.at-rest"
        },
        "result": {
          "const": "pass"
        },
        "subject_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "observed_at": {
          "type": "string",
          "format": "date-time"
        },
        "claims": {
          "$ref": "#/$defs/at_rest_claims"
        }
      }
    },
    "in_transit_attestation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["control", "result", "subject_sha256", "observed_at", "claims"],
      "properties": {
        "control": {
          "const": "encryption.in-transit"
        },
        "result": {
          "const": "pass"
        },
        "subject_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "observed_at": {
          "type": "string",
          "format": "date-time"
        },
        "claims": {
          "$ref": "#/$defs/in_transit_claims"
        }
      }
    },
    "rotation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["epoch", "phase"],
      "properties": {
        "epoch": {
          "type": "integer",
          "minimum": 1
        },
        "phase": {
          "enum": ["stable", "overlap"]
        }
      }
    },
    "auth_tag": {
      "type": "object",
      "additionalProperties": false,
      "required": ["algorithm", "key_id", "value"],
      "properties": {
        "algorithm": {
          "const": "hmac-sha256"
        },
        "key_id": {
          "$ref": "#/$defs/identifier"
        },
        "value": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        }
      }
    },
    "authenticator": {
      "type": "object",
      "additionalProperties": false,
      "required": ["algorithm", "key_id", "value"],
      "properties": {
        "algorithm": {
          "const": "ed25519"
        },
        "key_id": {
          "$ref": "#/$defs/identifier"
        },
        "value": {
          "type": "string",
          "pattern": "^[A-Za-z0-9+/]{86}==$"
        }
      }
    }
  }
}

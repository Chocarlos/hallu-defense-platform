{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hallu-defense.local/schemas/eval-smoke-scenario-result.schema.json",
  "title": "EvalSmokeScenarioResult",
  "type": "object",
  "required": [
    "id",
    "latency_ms",
    "expected_final_decision",
    "final_decision",
    "trace_present",
    "claim_ledger_present",
    "verdict_ledger_present",
    "expected_claims",
    "actual_claims",
    "expected_unsupported_claims",
    "unsupported_hits",
    "supported_verdicts",
    "supported_verdicts_with_evidence",
    "verdict_count",
    "cost_usd"
  ],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "latency_ms": { "type": "number", "minimum": 0 },
    "expected_final_decision": {
      "type": "string",
      "enum": ["allow", "repaired", "abstained", "blocked", "require_human_review"]
    },
    "final_decision": {
      "type": "string",
      "enum": ["allow", "repaired", "abstained", "blocked", "require_human_review"]
    },
    "trace_present": { "type": "boolean" },
    "claim_ledger_present": { "type": "boolean" },
    "verdict_ledger_present": { "type": "boolean" },
    "expected_claims": {
      "type": "array",
      "items": { "type": "string" }
    },
    "actual_claims": {
      "type": "array",
      "items": { "type": "string" }
    },
    "expected_unsupported_claims": {
      "type": "array",
      "items": { "type": "string" }
    },
    "unsupported_hits": { "type": "integer", "minimum": 0 },
    "supported_verdicts": { "type": "integer", "minimum": 0 },
    "supported_verdicts_with_evidence": { "type": "integer", "minimum": 0 },
    "verdict_count": { "type": "integer", "minimum": 0 },
    "cost_usd": { "type": "number", "minimum": 0 }
  },
  "additionalProperties": false
}

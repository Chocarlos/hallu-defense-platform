{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hallu-defense.local/schemas/release-deployment-subject.schema.json",
  "title": "ReleaseDeploymentSubject",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "tenant_id",
    "environment",
    "release_id",
    "deployment_revision",
    "source_repository",
    "source_commit",
    "workflow_ref",
    "workflow_sha256",
    "encryption_policy_sha256",
    "trust_store_sha256",
    "postgres_tls",
    "artifacts"
  ],
  "properties": {
    "schema_version": {
      "const": "release-deployment-subject.v1"
    },
    "tenant_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_-]{2,63}$"
    },
    "environment": {
      "enum": ["staging", "production"]
    },
    "release_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{2,127}$"
    },
    "deployment_revision": {
      "type": "integer",
      "minimum": 1
    },
    "source_repository": {
      "type": "string",
      "pattern": "^https://[A-Za-z0-9._/-]+$",
      "maxLength": 512
    },
    "source_commit": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}([0-9a-f]{24})?$"
    },
    "workflow_ref": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._/@-]{3,512}$"
    },
    "workflow_sha256": {
      "$ref": "#/$defs/sha256"
    },
    "encryption_policy_sha256": {
      "$ref": "#/$defs/sha256"
    },
    "trust_store_sha256": {
      "$ref": "#/$defs/sha256"
    },
    "postgres_tls": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "secret_resource_uid",
        "secret_name",
        "ca_key",
        "bundle_sha256",
        "mount_path",
        "sub_path",
        "rollout_revision",
        "rollout_sha256"
      ],
      "properties": {
        "secret_resource_uid": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{7,127}$"
        },
        "secret_name": {
          "type": "string",
          "pattern": "^[a-z0-9]([a-z0-9.-]{0,61}[a-z0-9])?$"
        },
        "ca_key": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{1,127}$"
        },
        "bundle_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "mount_path": {
          "type": "string",
          "pattern": "^/[A-Za-z0-9._/-]{2,511}$"
        },
        "sub_path": {
          "const": true
        },
        "rollout_revision": {
          "type": "integer",
          "minimum": 1
        },
        "rollout_sha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "maxItems": 64,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "image_digest", "configuration_sha256"],
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9._-]{1,63}$"
          },
          "image_digest": {
            "type": "string",
            "pattern": "^sha256:[0-9a-f]{64}$"
          },
          "configuration_sha256": {
            "$ref": "#/$defs/sha256"
          }
        }
      }
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    }
  }
}

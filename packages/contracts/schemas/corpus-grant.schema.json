{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hallu-defense.local/schemas/corpus-grant.schema.json",
  "title": "CorpusGrant",
  "type": "object",
  "required": [
    "tenant_id",
    "corpus_id",
    "reader_roles",
    "writer_roles",
    "version",
    "created_by",
    "updated_by",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "tenant_id": { "type": "string", "minLength": 1 },
    "corpus_id": { "type": "string", "minLength": 1 },
    "reader_roles": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "writer_roles": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "version": { "type": "integer", "minimum": 1 },
    "created_by": { "type": "string", "minLength": 1 },
    "updated_by": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" },
    "disabled_by": { "type": ["string", "null"], "minLength": 1 },
    "disabled_at": { "type": ["string", "null"], "format": "date-time" }
  },
  "additionalProperties": false
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hallu-defense.local/schemas/claim-verdict-v2.schema.json",
  "title": "ClaimVerdictV2",
  "x-contract-version": "2.0",
  "type": "object",
  "required": [
    "schema_version",
    "claim_id",
    "status",
    "confidence",
    "evidence_ids",
    "action",
    "reason",
    "validator_trace"
  ],
  "properties": {
    "schema_version": { "const": "2.0", "type": "string" },
    "claim_id": { "type": "string" },
    "status": {
      "type": "string",
      "enum": [
        "supported",
        "unsupported",
        "contradicted",
        "insufficient_evidence",
        "not_verifiable",
        "requires_human_review",
        "blocked_by_policy"
      ]
    },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "evidence_ids": { "type": "array", "items": { "type": "string" } },
    "action": {
      "type": "string",
      "enum": [
        "allow",
        "repair",
        "abstain",
        "block",
        "ask_clarification",
        "require_approval"
      ]
    },
    "reason": { "type": "string" },
    "validator_trace": { "type": "object", "additionalProperties": true }
  },
  "allOf": [
    {
      "if": {
        "required": ["status"],
        "properties": { "status": { "const": "blocked_by_policy" } }
      },
      "then": { "properties": { "action": { "const": "block" } } }
    },
    {
      "if": {
        "required": ["status"],
        "properties": { "status": { "const": "requires_human_review" } }
      },
      "then": { "properties": { "action": { "const": "require_approval" } } }
    },
    {
      "if": {
        "required": ["action"],
        "properties": { "action": { "const": "require_approval" } }
      },
      "then": { "properties": { "status": { "const": "requires_human_review" } } }
    }
  ],
  "additionalProperties": false
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hallu-defense.local/schemas/sandbox-run.schema.json",
  "title": "SandboxRun",
  "type": "object",
  "required": [
    "repo_ref",
    "commands",
    "exit_codes",
    "stdout",
    "stderr",
    "artifacts",
    "evidence",
    "network_policy",
    "verdict"
  ],
  "properties": {
    "repo_ref": { "type": "string", "minLength": 1 },
    "commands": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "exit_codes": {
      "type": "array",
      "items": { "type": "integer" }
    },
    "stdout": {
      "type": "array",
      "items": { "type": "string" }
    },
    "stderr": {
      "type": "array",
      "items": { "type": "string" }
    },
    "artifacts": {
      "type": "array",
      "items": { "type": "string" }
    },
    "evidence": {
      "type": "array",
      "items": { "$ref": "evidence.schema.json" }
    },
    "network_policy": { "type": "string", "enum": ["deny", "allowlisted"] },
    "verdict": {
      "type": "string",
      "enum": [
        "SUPPORTED",
        "PARTIALLY_SUPPORTED",
        "CONTRADICTED",
        "NOT_FOUND",
        "AMBIGUOUS",
        "STALE_SOURCE",
        "UNVERIFIABLE",
        "OUT_OF_SCOPE"
      ]
    }
  },
  "additionalProperties": false
}
